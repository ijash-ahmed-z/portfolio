---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
const profiles = await getCollection('profile');
const profile = profiles[0];
const posts = (await getCollection('posts', ({ data }) => data.published !== false))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Articles" description="Portfolio articles and notes" profile={profile}>
  <section class="section posts-page">
    <div class="container">
      <SectionTitle title="Articles" text="Publish blogs, notes and case-study articles from the admin dashboard." />
      <div class="post-grid">
        {posts.length ? posts.map((post) => (
          <a class="post-card soft-card" href={`/posts/${post.id}/`}>
            {post.data.cover ? <img src={post.data.cover} alt="" loading="lazy" /> : <div class="post-placeholder">Article</div>}
            <p>{post.data.date.toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' })}</p>
            <h2>{post.data.title}</h2>
            <span>{post.data.excerpt}</span>
          </a>
        )) : <div class="soft-card empty-state">Add articles from Admin -> Blog Posts / Articles.</div>}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .posts-page { padding-top: 7rem; }
  .post-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 1.5rem; }
  .post-card { padding: 1rem; transition: transform .2s ease; }
  .post-card:hover { transform: translateY(-4px); }
  .post-card img, .post-placeholder { aspect-ratio: 16/10; object-fit: cover; border-radius: 20px; margin-bottom: 1rem; background: var(--violet-soft); }
  .post-placeholder { display: grid; place-items: center; color: var(--violet); font-weight: 900; }
  .post-card p { color: var(--violet); font-weight: 800; margin: 0; }
  .post-card h2 { line-height: 1.15; margin: .4rem 0; }
  .post-card span { color: var(--muted); }
  .empty-state { padding: 1.5rem; color: var(--muted); font-weight: 800; }
  @media (max-width: 950px) { .post-grid { grid-template-columns: 1fr; } }
</style>
