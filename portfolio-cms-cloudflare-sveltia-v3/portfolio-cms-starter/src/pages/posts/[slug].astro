---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => data.published !== false);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
const profiles = await getCollection('profile');
const profile = profiles[0];
---
<BaseLayout title={post.data.seoTitle || post.data.title} description={post.data.seoDescription || post.data.excerpt} profile={profile}>
  <article class="section article">
    <div class="container narrow">
      <a class="back-link" href="/posts/">← All articles</a>
      <p class="kicker">{post.data.date.toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
      <h1 class="display-title">{post.data.title}</h1>
      <p class="body-large">{post.data.excerpt}</p>
      {post.data.cover && <img class="cover" src={post.data.cover} alt="" loading="lazy" />}
      <div class="content"><Content /></div>
    </div>
  </article>
</BaseLayout>

<style>
  .article { padding-top: 7rem; }
  .back-link { color: var(--violet); font-weight: 900; }
  h1 { font-size: clamp(4rem, 10vw, 8rem); margin: 0 0 1rem; }
  .cover { border-radius: 28px; margin: 2rem 0; box-shadow: var(--card); }
  .content :global(p), .content :global(li) { color: var(--muted); font-size: 1.1rem; }
  .content :global(h2), .content :global(h3) { font-family: Anton, Impact, 'Arial Narrow', sans-serif; text-transform: uppercase; letter-spacing: -0.02em; }
</style>
