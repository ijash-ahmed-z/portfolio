---
const { project, href } = Astro.props;
const data = project.data;
---
<a class="project-card" href={href} aria-label={`Open ${data.title}`}>
  {data.cover ? <img src={data.cover} alt={data.coverAlt || ''} loading="lazy" /> : <div class="placeholder">Upload cover</div>}
  <div class="overlay"></div>
  <div class="content">
    <span>{data.category || 'Project'}</span>
    <h3 class="display-title">{data.title}</h3>
    <p>{data.excerpt}</p>
    <small>View case study ↗</small>
  </div>
</a>

<style>
  .project-card {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 30px;
    min-height: clamp(330px, 47vw, 540px);
    background: #181820;
    box-shadow: var(--card);
    isolation: isolate;
  }
  .project-card img, .placeholder {
    width: 100%;
    height: 100%;
    min-height: inherit;
    object-fit: cover;
    transform: scale(1.02);
    transition: transform .55s ease, filter .55s ease;
  }
  .placeholder {
    display: grid;
    place-items: center;
    color: white;
    font-weight: 900;
    background: radial-gradient(circle at 20% 20%, rgba(152,0,255,.65), transparent 28%), linear-gradient(135deg, #28202f, #666073);
  }
  .overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,10,18,.08), rgba(10,10,18,.74));
    z-index: 1;
  }
  .content {
    position: absolute;
    inset: auto 0 0;
    z-index: 2;
    display: grid;
    justify-items: center;
    text-align: center;
    padding: clamp(1.4rem, 4vw, 3rem);
    color: white;
  }
  .content span {
    background: var(--violet);
    border-radius: 999px;
    padding: .35rem .85rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: .85rem;
  }
  .content h3 {
    font-size: clamp(2.2rem, 6vw, 5.2rem);
    margin: 0;
    max-width: 900px;
  }
  .content p {
    max-width: 760px;
    margin: .55rem auto .8rem;
    font-weight: 800;
    line-height: 1.35;
    font-size: clamp(1rem, 1.45vw, 1.25rem);
  }
  .content small { font-weight: 900; opacity: .94; }
  .project-card:hover img { transform: scale(1.07); filter: saturate(1.05) contrast(1.05); }
  .project-card:hover { outline: 2px solid rgba(152,0,255,.25); outline-offset: 4px; }
</style>
